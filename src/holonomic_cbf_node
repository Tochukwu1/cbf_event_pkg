#include <chrono>
#include <memory>
#include <cmath>
#include <algorithm>
#include <numbers>

#include "rclcpp/rclcpp.hpp"
#include "geometry_msgs/msg/twist.hpp" // for sending velocity commands
#include "tf2_msgs/msg/tf_message.hpp" // for receiving odometry as TF
#include <Eigen/Dense>

#include "tf2/LinearMath/Quaternion.h"
#include "tf2/LinearMath/Matrix3x3.h"

using namespace std::chrono_literals;
using std::placeholders::_1;

class HolonomicCBFNode : public rclcpp::Node
{
    public:
        HolonomicCBFNode() : Node("holonomic_cbf_node"), state_received_(false)
        {
            // Initialize parameters (gains, obstacle positions, limits)
            declare_all_parameters();
            load_parameters();
            
            // publishing Twist messages to "/cmd_vel"to move the robot
            cmd_pub_ = this->create_publisher<geometry_msgs::msg::Twist>("/cmd_vel", 1);
            // Listening to the "/holonomic_robot/pose" topic and when msg arrives, it triggers state_callback function
            state_sub_ = this->create_subscription<tf2_msgs::msg::TFMessage>("/holonomic_robot/pose", 1,
                                std::bind(&HolonomicCBFNode::state_callback, this, _1));

            // main control loop - excecutes trigger_loop at a fixed frequency
            auto timer_period = std::chrono::milliseconds(timer_period_ms_);
            trigger_timer_ = this->create_wall_timer(timer_period, std::bind(&HolonomicCBFNode::trigger_loop, this));

            // Initialize state vectors to zero
            q_current_ =  Eigen::Vector3d::Zero(); // [x, y, theta] in the global frame
            u_held_ =  Eigen::Vector2d::Zero(); // current commanded [v_x, v_y] in the global frame

            RCLCPP_INFO(this->get_logger(), "Holonomic ETC-CBF Node Initialized. Awaiting TF pose...")
        }

    private:
        rclcpp::Publisher<geometry_msgs::msgs::Twist>::SharedPtr cmd_pub_;
        rclcpp::Subscription<tf2_msgs::msg::TFMessage>::SharedPtr state_sub_;
        rclcpp::TimerBase::SharedPtr trigger_timer_;

        // State and Control Variables
        bool state_received_;
        Eigen::Vector3d q_current_;
        Eigen::Vector2d u_held_;

        // Environmental variables (obstacles and goal location)
        Eigen::Vector2d obs_center_;
        Eigen::Vector2d goal_;

        // Control parameters
        double robot_radius_;
        double obstacle_radius_;
        double epsilon_; // ETC trigger threshold
        double k_p_; // proportional gain for the nominal controller
        double max_v_; // maximum allowable linear velocity
        double goal_tolerance_; // distance to goal where the robot will stop
        int timer_period_ms_; // control loop frequency

        // A small constant to prevent division by zero in the QP solver
        const double MATH_TOL = 1e-6;

        // Registering parameters with the ROS2 parameter server
        void declare_all_parameters()
        {
            this->declare_parameter("robot_radius", 0.18);
            this->declare_parameter("obs_x", 1.5);
            this->declare_parameter("obs_y", -0.1);
            this->declare_parameter("obs_radius", 0.5);

            this->declare_parameter("goal_x", 3.0);
            this->declare_parameter("goal_y", 0.0);
            this->declare_parameter("goal_y", 0.05);

            this->declare_parameter("epsilon", 0.01);
            this->declare_parameter("k_p", 0.5);

            this->declare_parameter("max_v", 1.0);
            this->declare_parameter("timer_period_ms", 10);
        }

        // Fetches the current values from ROS2 parmater server
        void load_parameters()
        {
            robot_radius_ = this->get_parameter("robot_radius").as_double();
            obs_center_ = Eigen::Vector2d(
                            this->get_parameter("obs_x").as_double(),
                            this->get_parameter("obs_y").as_double()
                        );

            obs_radius_ = this->get_parameter("obs_radius").as_double();
            goal_ = Eigen::Vector2d(
                    this->get_parameter("goal_x").as_double(),
                    this->get_parameter("goal_y").as_double()
            );
            goal_tolerance_ =  this->get_parameter("goal_tolerance").as_double();
            epsilon_ = this->get_parameter("epsilon").as_double();
            k_p_ = this->get_parameter("k_p").as_double();
            max_v_ = this->get_parameter("max_v").as_double();
            timer_period_ms_ = this->get_parameter("timer_period_ms").as_int();
        }

        // Updates the robot's belief of where it is in the world - triggered automatically everytime TFMessage arrives.
        void state_callback(const tf2_msgs::msg::TFMessage::SharedPtr msg)
        {
            // A TFMessage contains an array of transforms so need to find one for the robot
            for (const auto& transform_stamped : msg->transforms)
            {
                if (transform_stamped.child_frame_id == "holonomic_robot")
                {
                    // Extract 2d translation (X, Y)
                    q_current_(0) =  transform_stamped.transform.translation.x;
                    q_current_(1) = transform_stamped.transform.translation.y;

                    // Extract Rotation (Yaw)
                    // the pose is given as a quarternion (x, y, z, w). Need to convert to Euler angles to get the Yaw.
                    tf2::quarternion q(
                        transform_stamped.transform.rotation.x,
                        transform_stamped.transform.rotation.y,
                        transform_stamped.transform.rotation.z,
                        transform_stamped.transform.rotation.w
                    );

                    tf2::Matrix3x3 m(q);
                    double roll, pitch, yaw;
                    m.getRPY(roll, pitch, yaw); // Extracts Roll, Pitch, Yaw

                    // Normalize yaw to bound it between [-pi, pi]
                    yaw = std::remainder(yaw, 2.0 * std::numbers::pi)

                    q_current_(2) = yaw;
                    state_received_ = true; // Flag to let the control loop it is safe to start calculating

                    break; // target frame found, no need to check the rest of the array
                }
            }
        }

        // Event-Triggered Control (ETC) Loop, running at a fixed frequency
        void trigger_loop()
        {
            // Don't calculate controls if we don't know where the robot is yet
            if (!state_received_)
            {
                return;
            }

            // Extract just X, Y position 
            Eigen::Vector2d p = q_current_.head<2>();

            // Check if we have reached the goal
            double dist_to_goal = (p - goal_).norm();
            if (dist_to_goal < goal_tolerance_)
            {
                u_held_ =  Eigen::Vector2d::Zero();
                publish_control(u_held_);
                RCLCPP_INFO_THROTTLE(this->get_logger(), *this->get_clock(), 2000, "Goal Reached! Idling.");
                return;
            }

            // Calculate Nominal Control - using P control pointing directly at the goal.
            // Because the robot is holonomic, it can move along this vector without turning first
            Eigen::Vector2d u_nom = -k_p_ * (p - goal_);

            # Evaluate the CBF safety Condition
            double h = h_barrier(q_current_); // distance to obstacle barrier
            double Lfh_val = Lf_h(q_current_);
            Eigen::RowVector2d Lgh_val = Lgh_val(q_current_);

            // Calculate the boundary condition 'b' for the safety inequality: Lf_h + Lg_h * u >= -alpha(h)
            double b = -alpha_fun(h) - Lfh_val;

            // residual
            double diff = b - Lgh_val.dot(u_held_);

            // ETC logic - when we do we update control

            // Condition 1: Safety breach imminent. The held control no longer satisfies the safety bound.
            bool is_cbf_trigger = (diff >= epsilon_);

            // Condition 2: Initilaization. we need to start moving
            bool is_startup = (u_held_.norm() < 0.01);

            // Condition 3: Recovery. We passed the obstacle safely, but our held control is still
            //avoiding it. We check the nominal path is safe, and if so, return to it.
            double nominal_diff = b - Lgh_val.dot(u_nom);
            bool is_recovery =  false;
            if (!is_cbf_trigger && (nominal_diff < -0.05))
            {
                //If our held control deviates significantly from the nominal path, reset it.
                if ((u_held_ - u_nom).norm() > 0.1)
                {
                    is_recovery = true;
                }
            }

            // solve and update control (zero-order-hold)
            
            // Only compute new control if an event was triggered. Otherwis, hold the previous control.
            if (is_cbf_trigger || is_recovery || is_startup)
            {
                // Solve the QP to find the closest safe velocity to our nominal velocity
                Eigen::Vector2d u_safe = solve_cbf_qp(q_current_, u_nom, b, Lgh_val);

                if (is_cbf_trigger)
                {
                    // ETC kick: overcompensate slightly away from the obstacle using the gradient.
                    // This gurantees the system wont trigger continuously (Zeno Behavior).
                    u_held_ = u_safe + (1.0 / epsilon_) * Lgh_val.transpose();
                }
                else
                {
                    // Normal safe update for startup and returning to the nominal path
                    u_held_ = u_safe;
                }

                // Actuator saturation
                u_held_(0) = std::clamp(u_held_(0), -max_v_, max_v_);
                u_held_(1) = std::clamp(u_held_(1), -max_v_, max_v_);

                // send held command to robot
                publish_control(u_held_);
            }

            // Translates the calculated global velocity into local robot commands
            void publish_control(const Eigen::Vector2d& u_global)
            {
                double theta = q_current_(2); // robot's current yaw

                // Kinetic frame tarnsformation
                // Our CBF calculates velocities in the Global (World/Odom) frame.
                // However, ROS 2 /cmd_vel expects velocities in the Local (base_link) frame.
                // We use a 2D rotation matrix to rotate the global velocity vector into the robot's perspective.

                double vx_local = u_global(0) * std::cos(theta) + u_global(1) * std::sin(theta);
                double vy_local = -u_global(0) * std::sin(theta) + u_global(1) * std::cos(theta);

                // Cap local frame velocities
                vx_local = std::clamp(vx_local, -max_v_, max_v_);
                vy_local = std::clamp(vy_local, -max_v_, max_v_);

                auto cmd =geometry_msgs::msg::Twist();
                cmd.linear.x = vy_local; // Forward/Backward speed relative to the chassis
                cmd.linear.y = vy_local; // Left/Right (strafing) speed relative to the chassis

                // Set angular rotation to 0 for 2D translation only
                cmd.angular.z = 0.0;
                cmd_pub_->publish(cmd);

            }

            // Barrie function h. If h > 0, we are safe. If h < 0, a collision occurred.
            double h_barrier(const Eigen::Vector3d& q)
            {
                Eigen::Vector2d p = q.head<2>(); // Current X, Y
                
                // Safety boundary, added a small 5cm safety buffer
                double safe_radius = robot_radius_ + obs_radius_ + 0.05;

                return (p - obs_center_).squaredNorm() - (safe_radius * safe_radius);

            }

            // Lie derivative of h with respect to drift f
            double Lf_h(const Eigen::Vector3d& q)
            {
                return 0.0;
            }

            // Lie Derivative of h with respect to g
            Eigen::RowVector2d Lg_h(const Eigen::Vector3d& q)
            {
                Eigen::Vector2d p = q.head<2>();
                Eigen::Vector2d diff = p - obs_center_;
                return 2.0 * diff.transpose(); 
            }

            // Class K function for the CBF inequality.
            double alpha_fun(double h)
            {
                 return 1.0 * h; 
                 
            }

            // Solves the Quadratic Program (QP).
            // Objective: Minimize ||u - u_nom||^2 
            // Subject to: Lgh * u >= b
            Eigen::Vector2d solve_cbf_qp(const Eigen::Vector3d& q, const Eigen::Vector2d& u_nom, double b_cbf, const Eigen::RowVector2d& Lgh_val)
            {
                // If the nominal control is already safe, just use it.
                if (Lgh_val.dot(u_nom) >= b_cbf) {
                    return u_nom;
                }

                double A_norm_sq = Lgh_val.squaredNorm();
                
                // If the gradient is essentially zero (e.g., exactly at the center of the obstacle), return 0 to avoid dividing by 0.
                if (A_norm_sq < MATH_TOL) {
                    return Eigen::Vector2d::Zero();
                }

                // Calculate the Lagrangian multiplier to strictly satisfy the boundary condition
                double lambda = (b_cbf - Lgh_val.dot(u_nom)) / A_norm_sq;
                
                // Apply the correction to the nominal control
                return u_nom + lambda * Lgh_val.transpose();
            }
        };

// Standard ROS 2 entry point
int main(int argc, char * argv[])
{
    rclcpp::init(argc, argv);
    // 'spin' keeps the node alive and processing callbacks until ctrl+c is pressed
    rclcpp::spin(std::make_shared<HolonomicCBFNode>());
    rclcpp::shutdown();
    return 0;
}